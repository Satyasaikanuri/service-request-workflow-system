# Database URL configuration
# Format: mysql://username:password@host:port/database_name
MYSQL_PUBLIC_URL=mysql://root:password@localhost:3306/serviceportal

# Server Port
PORT=8080

# Security Secrets
JWT_SECRET=mySecretKeyMySecretKeyMySecretKey123456
ADMIN_SECRET=AdminSecret123

# Mail Server Configurations (Development: Mailtrap, Production: SMTP)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
